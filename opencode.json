{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "zotero": {
      "type": "local",
      "command": ["cargo", "run", "--release", "--"],
      "environment": {
        "ZOTERO_API_KEY": "{env:ZOTERO_API_KEY}",
        "ZOTERO_LIBRARY_ID": "{env:ZOTERO_LIBRARY_ID}",
        "ZOTERO_LIBRARY_TYPE": "{env:ZOTERO_LIBRARY_TYPE}",
        "WEBDAV_URL": "{env:WEBDAV_URL}",
        "WEBDAV_USERNAME": "{env:WEBDAV_USERNAME}",
        "WEBDAV_PASSWORD": "{env:WEBDAV_PASSWORD}",
        "RUST_LOG": "info"
      },
      "enabled": true
    }
  }
}
